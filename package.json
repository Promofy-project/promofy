{
  "name": "promofy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:reset": "supabase db reset && tsx scripts/seed-users.ts",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "seed:users": "tsx scripts/seed-users.ts",
    "seed:users:hosted": "tsx scripts/seed-users.ts --hosted",
    "test:rls": "tsx scripts/test-rls.ts",
    "test:rls:hosted": "tsx scripts/test-rls.ts --hosted",
    "test:fase2": "tsx scripts/test-fase2.ts",
    "test:fase2:hosted": "tsx scripts/test-fase2.ts --hosted",
    "verify:fase1": "npm run db:reset && npm run test:rls && npm run build",
    "verify": "npm run db:reset && npm run test:rls && npm run test:fase2 && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.110.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "0.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "17.4.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "4.23.0",
    "typescript": "^5"
  }
}
