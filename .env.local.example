# Promofy — Supabase LOCAL (Fase 1)
# Copie para .env.local e preencha com a saída de `supabase start`
# (ou `supabase status -o env`). NUNCA versionar .env.local.
#
# Nota: projetos hosted novos preferem chaves sb_publishable_*/sb_secret_*;
# o stack local do CLI emite as chaves legadas anon/service_role — os nomes
# abaixo seguem o spec da Fase 1 e funcionam em ambos.

# (portas do promofy ficam na faixa 553xx para conviver com outros stacks locais)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SOMENTE servidor (scripts/seed, scripts/test-rls). Jamais no browser,
# jamais prefixar com NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
